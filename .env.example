# Bind address / port for the proxy.
HOST=127.0.0.1
PORT=8787

# Fallback model when a request doesn't specify one.
DEFAULT_MODEL=claude-opus-4-8

# Optional bearer token to protect the proxy. If set, clients must send
# `Authorization: Bearer <API_KEY>`. Leave unset for an open localhost proxy.
# API_KEY=

# Subscription billing is the whole point: by default we strip ANTHROPIC_API_KEY
# from the child env so the Agent SDK uses your logged-in Claude credentials
# (claude /login) and bills your subscription. Set to 1 to instead allow a
# metered ANTHROPIC_API_KEY through (pay-per-token).
# ALLOW_API_KEY=0

# Override the claude CLI the SDK drives (e.g. the Nix-provided one). Defaults
# to the CLI bundled with @anthropic-ai/claude-agent-sdk.
# CLAUDE_CLI_PATH=/run/current-system/sw/bin/claude
